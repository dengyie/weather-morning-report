WEATHER_REPORT_DB_PATH=var/weather-report.db
WEATHER_REPORT_SECRET_KEY_FILE=var/secret.key
# Keep 127.0.0.1 for local-only access. Use 0.0.0.0 to allow direct HTTP
# access from other hosts.
WEB_BIND=127.0.0.1
WEB_PORT=8766

# Legacy v0.2 runtime configuration retained while the v3 worker is developed.
TIMEZONE=Asia/Shanghai
LOCATION_NAME=Changning District, Shanghai
LOCATION_QUERY=Changning,Shanghai
CACHE_PATH=var/weather_snapshot.json
CACHE_MAX_AGE_HOURS=12
SETTINGS_PATH=var/settings.json
RECIPIENT_NAME=
RECIPIENT_EMAIL=
RECIPIENTS_JSON=
ADMIN_EMAIL=
SENDER_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SECURITY=starttls
